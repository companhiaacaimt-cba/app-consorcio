export default async function handler(req, res) {
  if (req.method !== 'POST') return res.status(405).json({ error: 'Método não permitido' });

  try {
    const { prompt, aspect_ratio = "1:1" } = req.body;
    const apiKey = process.env.FAL_KEY;

    if (!apiKey) return res.status(500).json({ error: 'FAL_KEY não configurada na Vercel.' });

    // Chamada para o modelo Flux Schnell (Rápido e excelente com textos)
    const response = await fetch('https://fal.run/fal-ai/flux/schnell', {
      method: 'POST',
      headers: {
        'Authorization': `Key ${apiKey}`,
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        prompt: prompt,
        image_size: aspect_ratio === "9:16" ? "portrait_4_3" : "square", 
        num_inference_steps: 4,
        enable_safety_checker: true
      })
    });

    const data = await response.json();
    
    if (!response.ok) throw new Error(data.detail || 'Erro ao gerar imagem');

    // Retorna a URL da imagem gerada
    res.status(200).json({ url: data.images[0].url });

  } catch (error) {
    console.error('Erro na API de Imagem:', error);
    res.status(500).json({ error: error.message });
  }
}
