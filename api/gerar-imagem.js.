export default async function handler(req, res) {
  if (req.method !== 'POST') return res.status(405).json({ error: 'Método não permitido' });

  try {
    // Agora aceitamos a imagem de referência do frontend
    const { prompt, aspect_ratio = "1:1", reference_image } = req.body;
    const apiKey = process.env.FAL_KEY;

    if (!apiKey) return res.status(500).json({ error: 'FAL_KEY não configurada na Vercel.' });

    // Configuração padrão para texto -> imagem (Flux Schnell)
    let endpoint = 'https://fal.run/fal-ai/flux/schnell';
    let payload = {
      prompt: prompt,
      image_size: aspect_ratio === "9:16" ? "portrait_4_3" : "square",
      num_inference_steps: 4,
      enable_safety_checker: true
    };

    // Se o usuário enviar uma imagem, mudamos para o motor de Imagem -> Imagem
    if (reference_image) {
      endpoint = 'https://fal.run/fal-ai/flux/dev/image-to-image';
      payload = {
        prompt: prompt,
        image_url: reference_image, // Base64 da imagem
        strength: 0.85, // Força da alteração (0 a 1). 0.85 permite alterar mantendo a estrutura.
        image_size: aspect_ratio === "9:16" ? "portrait_4_3" : "square",
        enable_safety_checker: true
      };
    }

    const response = await fetch(endpoint, {
      method: 'POST',
      headers: {
        'Authorization': `Key ${apiKey}`,
        'Content-Type': 'application/json'
      },
      body: JSON.stringify(payload)
    });

    const data = await response.json();
    
    if (!response.ok) throw new Error(data.detail || 'Erro ao gerar imagem');

    res.status(200).json({ url: data.images[0].url });

  } catch (error) {
    console.error('Erro na API de Imagem:', error);
    res.status(500).json({ error: error.message });
  }
}
